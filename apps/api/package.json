{
  "name": "@nest/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "db:create": "ts-node -r tsconfig-paths/register src/database/scripts/db-create.ts",
    "db:drop": "ts-node -r tsconfig-paths/register src/database/scripts/db-drop.ts --force",
    "db:reset": "ts-node -r tsconfig-paths/register src/database/scripts/db-reset.ts --force",
    "db:fresh": "ts-node -r tsconfig-paths/register src/database/scripts/db-fresh.ts",
    "db:fresh:force": "ts-node -r tsconfig-paths/register src/database/scripts/db-fresh.ts --force",
    "db:schemas": "ts-node -r tsconfig-paths/register src/database/scripts/db-schemas.ts",
    "db:schemas:reset": "ts-node -r tsconfig-paths/register src/database/scripts/db-reset-schemas.ts --force",
    "db:truncate": "ts-node -r tsconfig-paths/register src/database/scripts/db-truncate.ts --force",
    "db:truncate:with-migrations": "ts-node -r tsconfig-paths/register src/database/scripts/db-truncate.ts --force --include-migrations",
    "db:migrate": "ts-node -r tsconfig-paths/register src/database/scripts/migrate.ts run",
    "db:migrate:revert": "ts-node -r tsconfig-paths/register src/database/scripts/migrate.ts revert",
    "db:migrate:show": "ts-node -r tsconfig-paths/register src/database/scripts/migrate.ts show",
    "db:sql-assets": "ts-node -r tsconfig-paths/register src/database/scripts/sync-sql-assets.ts",
    "db:sql-assets:force": "ts-node -r tsconfig-paths/register src/database/scripts/sync-sql-assets.ts --force",
    "db:migrate:prod": "node dist/database/scripts/migrate.js run",
    "db:migrate:prod:revert": "node dist/database/scripts/migrate.js revert",
    "db:migration:generate": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:generate src/database/migrations/InitialSchema",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/scripts/db-seed.ts",
    "db:seed:force": "ts-node -r tsconfig-paths/register src/database/scripts/db-seed.ts --force",
    "test": "NODE_ENV=test jest --runInBand",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:unit": "NODE_ENV=test jest --runInBand --testPathIgnorePatterns=/node_modules/ --testPathIgnorePatterns=/dist/ --testPathIgnorePatterns=/test/e2e/",
    "test:e2e": "NODE_ENV=test jest --runInBand --config ./test/jest-e2e.json",
    "test:e2e:watch": "NODE_ENV=test jest --watch --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nestjs-i18n": "^10.6.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "qs": "^6.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.0.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.18.0",
    "@types/qs": "^6.15.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "execa": "^9.6.1",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
